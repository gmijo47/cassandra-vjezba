CREATE TABLE IF NOT EXISTS tecaj (
  tecaj_id      UUID PRIMARY KEY,
  naziv         TEXT,
  instruktor    TEXT,
  kategorija    TEXT,
  cijena        DECIMAL,
  trajanje_sati INT
);

CREATE TABLE IF NOT EXISTS upis (
  student_id   UUID,
  tecaj_id     UUID,
  datum_upisa  TIMESTAMP,
  napredak     INT,
  status       TEXT,
  PRIMARY KEY (student_id, tecaj_id)
